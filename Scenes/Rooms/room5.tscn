[node name="ExplanationLabel" type="RichTextLabel" parent="AnalystBoard/AnalystPopup/Panel" unique_id=595970342]
layout_mode = 0
offset_left = -22.0
offset_top = -6.0
offset_right = 284.0
offset_bottom = 176.0
theme_override_colors/default_color = Color(0, 0, 0, 1)
theme_override_fonts/normal_font = ExtResource("10_fv1an")
theme_override_font_sizes/normal_font_size = 15
bbcode_enabled = true
text = "[color=#170C79]Hierarchical inheritance[/color] in Java is a type of inheritance where multiple child classes inherit from a single parent class.

The [color=#170C79]parent class[/color] contains common properties and behaviors, while the child classes inherit those features and can also have their own unique features.

Example:
A parent class called [color=#170C79]“Animal”[/color] can be inherited by child classes like [color=#170C79]“Dog,” “Cat,” and “Bird.”[/color] All of them share common behaviors from [color=#170C79]“Animal”[/color], but each also has its own specific behavior.

This is called [color=#170C79]hierarchical inheritance[/color] because one superclass is connected to several subclasses in a hierarchy structure."

