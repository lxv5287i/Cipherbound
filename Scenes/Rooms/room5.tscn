text = "public class Machine {
    String name
    Machine (String name) {
       [color=#FF0000][u]  1   [/u][/color].name = name;         
    }
  void [color=#FF0000][u]  2   [/u][/color] {
   System.out.println(name + \": SYSTEM ONLINE\");
    }
}

class CombatRobot [color=#FF0000][u]  3   [/u][/color] Machine {    
    CombatRobot(String name) {
        [color=#FF0000][u]  4   [/u][/color](name);               
    }
       [color=#FF0000][u]  5    [/u][/color]{
        System.out.println(name + \": FIRING WEAPONS\");
    }
}

class Drone [color=#FF0000][u]  6    [/u][/color] CombatRobot {      
    Drone([color=#FF0000][u]  7    [/u][/color]) {
        super(name);
    }
    void fly() {
       [color=#FF0000][u]  8    [/u][/color](name + \": TAKING FLIGHT\");
    }
}
"
